{
  "name": "graphql-api",
  "version": "1.0.0",
  "description": "GraphQL API with Apollo Server v4, Express, Mongoose and TypeScript",
  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "cd client && npm install --include=dev && npm run build && cd .. && tsc",
    "start": "node dist/index.js",
    "seed": "ts-node -P scripts/tsconfig.json scripts/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "graphql": "^16.9.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.1",
    "mongoose": "^8.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "ts-node src/index.ts"
  }
}
