# Copy this file to .env and fill in your values

# MongoDB connection URI (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/biblioteca

# Secret key for signing JWTs (use a long random string in production)
JWT_SECRET=supersecret

# Server port (default: 4000)
PORT=4000

# Node environment (development | production)
NODE_ENV=development

# Allowed CORS origin in production (set to your Render URL)
CLIENT_ORIGIN=http://localhost:5173

# GraphQL endpoint for the React client (leave blank to use relative /graphql)
VITE_API_URL=/graphql
